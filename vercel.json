{
  "builds": [
    {
      "src": "backend/api/main.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 300 }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/main.py"
    }
  ],
  "crons": [
    { "path": "/api/cron/report",  "schedule": "0 * * * *" },
    { "path": "/api/check-alerts", "schedule": "*/15 * * * *" }
  ]
}

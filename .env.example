# Claude / Anthropic
ANTHROPIC_API_KEY=

# FRED (indicadores econômicos EUA)
FRED_API_KEY=

# EIA (estoques semanais de petróleo/gasolina/gás EUA — grátis em https://www.eia.gov/opendata/register.php)
EIA_API_KEY=

# NewsAPI
NEWS_API_KEY=

# ScraperAPI
SCRAPER_API_KEY=

# Cron (autenticação dos endpoints /api/check-alerts e /api/cron/report)
CRON_SECRET=

# Webhook (verificação de origem do POST /api/webhook).
# Opt-in: se vazio, o webhook aceita qualquer origem (comportamento legado).
# Ao preencher, atualize a URL do webhook na Evolution para incluir ?token=<valor>
# ou configure o header x-webhook-secret.
WEBHOOK_SECRET=

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://46.202.179.33:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=noticiasgg
# Formato de payload: deixe vazio/false para v1.8.2; defina true ao migrar para Evolution v2
EVOLUTION_API_V2=

# Número WhatsApp autorizado (com DDI, sem + e sem traços, ex: 5534999990000)
AUTHORIZED_NUMBER=
# Fallback de destino quando remoteJid é LID
REPLY_TO_NUMBER=

# Supabase (histórico de mensagens)
SUPABASE_URL=
SUPABASE_KEY=
